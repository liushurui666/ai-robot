# OpenAI-compatible model service
MODEL_API_KEY=replace-me
MODEL_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini

# Feishu application (used both by nanobot and internal-group delivery)
FEISHU_APP_ID=cli_replace_me
FEISHU_APP_SECRET=replace-me

# Protects the nanobot WebUI token bootstrap. Generate a long random value.
NANOBOT_WEBUI_SECRET=replace-with-at-least-32-random-characters

# External-group credentials passed only to the MCP process. Keep this on one line.
# Register the keys (not values) with `reminder-admin add-target`.
FEISHU_TARGET_SECRETS_JSON={}
# Example:
# FEISHU_TARGET_SECRETS_JSON={"CUSTOMER_GROUP_WEBHOOK":"https://open.feishu.cn/open-apis/bot/v2/hook/...","CUSTOMER_GROUP_SECRET":"..."}
